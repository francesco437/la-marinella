  <script>
    const editableSelectors = [
      "#giornaliero td[contenteditable='true']",
      "#settimanale-soci td[contenteditable='true']",
      "#settimanale-team td[contenteditable='true']",
      "#note-operative"
    ];

    function getEditableElements() {
      return editableSelectors.flatMap((selector) => [...document.querySelectorAll(selector)]);
    }

    function saveLocal() {
      const data = getEditableElements().map((el) => el.innerHTML);
      localStorage.setItem("rosterChioscoSpiaggiaV2", JSON.stringify(data));
      setStatus("Modifiche salvate nel browser.");
    }

    function loadLocal() {
      const raw = localStorage.getItem("rosterChioscoSpiaggiaV2");
      if (!raw) {
        setStatus("Nessun salvataggio trovato su questo browser.");
        return;
      }

      const data = JSON.parse(raw);
      getEditableElements().forEach((el, index) => {
        if (typeof data[index] !== "undefined") {
          el.innerHTML = data[index];
        }
      });

      setStatus("Dati ricaricati dal browser.");
    }

    function setStatus(message) {
      const target = document.getElementById("status");
      target.textContent = message;
      clearTimeout(window.statusTimer);
      window.statusTimer = setTimeout(() => {
        target.textContent = "";
      }, 2600);
    }
  </script>
